# =========================================================================
# Second Brain OS — Environment Configuration
# Copy this file to .env and fill in your Gemini API key.
# Get your key at: https://aistudio.google.com/apikey
# =========================================================================

# --- Google Gemini Settings ---
GEMINI_API_KEY=your-gemini-api-key-here

# LLM model for chat (Gemini 2.5 Flash is fast and free-tier compatible)
LLM_MODEL=gemini-2.5-flash

# Embedding model for vector search
EMBEDDING_MODEL=gemini-embedding-2

# Embedding vector dimensions (768 is output dimension we configure for gemini-embedding-2)
GEMINI_EMBEDDING_DIMENSION=768

# --- Database Paths ---
# Directory where LanceDB will store vector data
LANCEDB_DIR=./lancedb_data

# SQLite filename for notes, tags, and conversations
SQLITE_DB_PATH=second_brain.db
