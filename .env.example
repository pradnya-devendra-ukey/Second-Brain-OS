# =========================================================================
# Second Brain OS — Environment Configuration Template
# Copy this file to .env and fill in your values. Never commit .env itself.
# =========================================================================

# --- OpenAI Settings (Cloud) ---
# Required only when USE_LOCAL_LLM=False
OPENAI_API_KEY=sk-...your-key-here...

# LLM model to use
LLM_MODEL=gpt-4o-mini

# Embedding model to use
EMBEDDING_MODEL=text-embedding-3-small

# --- Ollama Settings (Local & Offline) ---
# Set USE_LOCAL_LLM=True to run fully offline with Ollama
USE_LOCAL_LLM=False

# Base URL where Ollama is running (default for local installs)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama LLM model name (run: ollama pull llama3)
OLLAMA_LLM_MODEL=llama3

# Ollama Embedding model name (run: ollama pull nomic-embed-text)
# NOTE: nomic-embed-text produces 768-dim vectors; OpenAI produces 1536-dim.
# If you switch between providers, the LanceDB table is auto-recreated.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Database Paths ---
# Directory where LanceDB will store vector data
LANCEDB_DIR=./lancedb_data

# SQLite filename for notes, tags, and conversations
SQLITE_DB_PATH=second_brain.db
