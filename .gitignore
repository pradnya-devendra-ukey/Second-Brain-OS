!data/pdfs/LLM.pdf
data/notes/*
!data/notes/.gitkeep

# Python compilation and caching
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# Operating System files
.DS_Store
Thumbs.db
desktop.ini

# App-specific logs & generated folders
*.log
.system_generated/
logs/
browser/
CORTEX_*
